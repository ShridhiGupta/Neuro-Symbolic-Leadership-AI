{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "functions": {
    "api/assessment.js": {
      "runtime": "nodejs18.x"
    },
    "api/upload-text.js": {
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    {
      "src": "/api/assessment/evaluate",
      "dest": "/api/assessment"
    },
    {
      "src": "/api/upload/text",
      "dest": "/api/upload-text"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "BACKEND_URL": "https://your-backend-api.com",
    "REACT_APP_API_URL": "https://your-vercel-app.vercel.app"
  }
}
